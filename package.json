{
	"private": true,
	"description": "Unbound container — validating, recursive, caching DNS resolver with DNSSEC support",
	"author": "Anthony Champagne <dev@anthonychampagne.fr>",
	"scripts": {
		"test": "vitest run",
		"tsc:check": "tsc -noEmit -p ./tsconfig.json",
		"biome:check": "biome check --error-on-warnings",
		"biome:fix": "biome check --write",
		"biome:fix-unsafe": "biome check --write --unsafe",
		"markdownlint:check": "markdownlint-cli2",
		"markdownlint:fix": "markdownlint-cli2 --fix",
		"postinstall": "is-ci || lefthook install"
	},
	"devDependencies": {
		"@types/node": "24.13.3",
		"@biomejs/biome": "2.5.4",
		"tsx": "4.23.1",
		"typescript": "6.0.3",
		"lefthook": "2.1.10",
		"markdownlint-cli2": "0.23.1",
		"is-ci": "4.1.0",
		"@ac-essentials/tsconfig": "0.5.0",
		"@ac-essentials/cli": "0.1.4",
		"@ac-essentials/misc-util": "0.6.1",
		"@ac-essentials/biome-config": "0.4.0",
		"@ac-essentials/markdownlint-cli2-config": "0.1.0",
		"vitest": "4.1.10"
	}
}
